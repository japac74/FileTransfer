{
	"ChunkSize": 1048576,
	"Serilog": {
		"Properties": {
			"ApplicationName": "File Transfer"
		},
		"Using": [ "Serilog.Sinks.Console" ],
		"MinimumLevel": {
			"Default": "Information",
			"Override": {
				"Microsoft": "Warning",
				"Microsoft.AspNetCore": "Warning"
			}
		},
		"WriteTo": [
			{
				"Name": "Console"
			}
		],
		"Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
	}
}